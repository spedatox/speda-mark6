# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Multi-provider LLM routing ─────────────────────────────────────────────────
# Model refs are "provider:model" — e.g. "openai:gpt-4o", "gemini:gemini-2.5-flash",
# "ollama:llama3.1:8b" (Ollama = local, dev/testing only). Bare names = Anthropic.
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434/v1
# Override the profile's default models without touching code (empty = profile):
# LLM_MAIN_MODEL=
# LLM_BACKGROUND_MODEL=
# Comma-separated "provider:model" refs tried in order when a provider call fails:
# LLM_FALLBACK_CHAIN=

# ── Database ───────────────────────────────────────────────────────────────────
# Compose builds the app's DATABASE_URL from POSTGRES_* below. For the dev
# backend (uvicorn, no Docker) set DATABASE_URL directly instead.
DATABASE_URL=postgresql+asyncpg://speda:speda@localhost:5432/speda
# Postgres credentials (used by docker-compose). CHANGE THE PASSWORD for prod —
# it only applies on a FRESH database volume.
POSTGRES_USER=speda
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=speda

# ── Auth ───────────────────────────────────────────────────────────────────────
# Single service credential — sent as X-API-Key by the desktop app / scripts and
# required on every endpoint. Use a long random value, e.g.
#   python -c "import secrets;print(secrets.token_urlsafe(48))"
SPEDA_API_KEY=change-me-before-production

# Shared secret for the n8n webhook trigger (X-N8N-Secret header).
N8N_SECRET=change-me-n8n-secret

# ── CORS ─────────────────────────────────────────────────────────────────────--
# Comma-separated browser origins allowed to call the API. Leave EMPTY for the
# desktop app (not a browser origin). Never use "*" on a public server.
# CORS_ALLOWED_ORIGINS=https://app.example.com

# ── Public domain (enables Caddy auto-HTTPS in docker-compose) ───────────────────
# Set to your domain so deploy.sh starts Caddy with a Let's Encrypt cert.
# DNS A record must point at this server and ports 80/443 must be open.
# DOMAIN=speda.example.com

# ── Automations (n8n control plane + Telegram delivery) ────────────────────────
# n8n REST API — create the key in n8n: Settings → n8n API. URL defaults to the
# docker-compose service; override only if n8n runs elsewhere.
# N8N_API_URL=http://n8n:5678
# N8N_API_KEY=
# URL n8n workflows use to call back into SPEDA (/trigger). Compose-internal by
# default; set to your public https://domain if n8n is hosted separately.
# SPEDA_CALLBACK_URL=http://app:8000

# Telegram bot for proactive pings — create one with @BotFather, paste the token,
# then use Settings → Automations → "Connect Telegram" in the app (no chat id
# needed; it's captured automatically when you tap Start).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=   # optional manual fallback

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ── Temp outputs ───────────────────────────────────────────────────────────────
TEMP_OUTPUTS_DIR=/tmp/speda_outputs

# ── MCP servers (fill in as each is configured) ────────────────────────────────
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# NOTION_OAUTH_REDIRECT=http://localhost:8000/oauth/notion/callback
# GOOGLE_WORKSPACE_CLIENT_ID=
# GOOGLE_WORKSPACE_CLIENT_SECRET=
# BRAVE_SEARCH_API_KEY=
# ALPHA_VANTAGE_API_KEY=
# TAVILY_API_KEY=
# EXA_API_KEY=
# GITHUB_TOKEN=

# ── OSS Adapters ───────────────────────────────────────────────────────────────
# GPT_RESEARCHER_URL=http://localhost:8000
# SHANNON_URL=http://localhost:9000
