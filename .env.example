# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Multi-provider LLM routing ─────────────────────────────────────────────────
# Model refs are "provider:model" — e.g. "openai:gpt-4o", "gemini:gemini-2.5-flash",
# "ollama:llama3.1:8b" (Ollama = local, dev/testing only). Bare names = Anthropic.
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434/v1
# Override the profile's default models without touching code (empty = profile):
# LLM_MAIN_MODEL=
# LLM_BACKGROUND_MODEL=
# Comma-separated "provider:model" refs tried in order when a provider call fails:
# LLM_FALLBACK_CHAIN=

# ── Database ───────────────────────────────────────────────────────────────────
# Compose builds the app's DATABASE_URL from POSTGRES_* below. For the dev
# backend (uvicorn, no Docker) set DATABASE_URL directly instead.
DATABASE_URL=postgresql+asyncpg://speda:speda@localhost:5432/speda
# Postgres credentials (used by docker-compose). CHANGE THE PASSWORD for prod —
# it only applies on a FRESH database volume.
POSTGRES_USER=speda
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=speda

# ── Auth ───────────────────────────────────────────────────────────────────────
# Single service credential — sent as X-API-Key by the desktop app / scripts and
# required on every endpoint. Use a long random value, e.g.
#   python -c "import secrets;print(secrets.token_urlsafe(48))"
SPEDA_API_KEY=change-me-before-production

# Shared secret for the n8n webhook trigger (X-N8N-Secret header).
N8N_SECRET=change-me-n8n-secret

# ── CORS ─────────────────────────────────────────────────────────────────────--
# Comma-separated browser origins allowed to call the API. Leave EMPTY for the
# desktop app (not a browser origin). Never use "*" on a public server.
# CORS_ALLOWED_ORIGINS=https://app.example.com

# ── Public domain (enables Caddy auto-HTTPS in docker-compose) ───────────────────
# Set to your domain so deploy.sh starts Caddy with a Let's Encrypt cert.
# DNS A record must point at this server and ports 80/443 must be open.
# DOMAIN=speda.example.com

# ── Automations (n8n control plane + Telegram delivery) ────────────────────────
# n8n REST API — create the key in n8n: Settings → n8n API. URL defaults to the
# docker-compose service; override only if n8n runs elsewhere.
# N8N_API_URL=http://n8n:5678
# N8N_API_KEY=
# URL n8n workflows use to call back into SPEDA (/trigger). Compose-internal by
# default; set to your public https://domain if n8n is hosted separately.
# SPEDA_CALLBACK_URL=http://app:8000

# Telegram bot for proactive pings — create one with @BotFather, paste the token,
# then use Settings → Automations → "Connect Telegram" in the app (no chat id
# needed; it's captured automatically when you tap Start).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=   # optional manual fallback

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ── Temp outputs ───────────────────────────────────────────────────────────────
TEMP_OUTPUTS_DIR=/tmp/speda_outputs

# ── MCP servers (fill in as each is configured) ────────────────────────────────
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# NOTION_OAUTH_REDIRECT=http://localhost:8000/oauth/notion/callback
# GOOGLE_WORKSPACE_CLIENT_ID=
# GOOGLE_WORKSPACE_CLIENT_SECRET=
# BRAVE_SEARCH_API_KEY=
# ALPHA_VANTAGE_API_KEY=
# TAVILY_API_KEY=
# EXA_API_KEY=
# GITHUB_TOKEN=

# ── News desk (two-tier RSS + NewsData.io) ──────────────────────────────────────
# Tier 1 (RSS) is keyless and always on — driven by an n8n cron → POST /news/poll.
# Tier 2 (NewsData.io) needs a free key from https://newsdata.io (200 req/day);
# empty disables the news_deep_dive tool. Extra feeds: comma-separated RSS URLs.
# NEWSDATA_API_KEY=
# NEWS_EXTRA_FEEDS=
# NEWS_RETENTION_DAYS=14
# NEWS_FLASH_COOLDOWN_MIN=120

# ── Maps & navigation (get_route / find_places) ─────────────────────────────────
# ONE Google Cloud API key with these APIs enabled: Routes API, Places API (New),
# Geocoding API. Requires a billing account on the project (a card must be on file;
# per-SKU free tiers keep single-user usage effectively $0). This is NOT the same as
# the Gmail/Calendar OAuth above — Maps is a separate product/billing credential.
# Restrict the key to those 3 APIs + your server IP. Empty disables both nav tools.
# GOOGLE_MAPS_API_KEY=
# Fallback origin when no live client location is shared (e.g. a Telegram turn):
# OWNER_HOME_LAT=41.0082
# OWNER_HOME_LNG=28.9784

# ── OSS Adapters ───────────────────────────────────────────────────────────────
# GPT_RESEARCHER_URL=http://localhost:8000
# SHANNON_URL=http://localhost:9000

# ── Sandbox (SPEDA's run_command computer) ──────────────────────────────────────
# In Docker this is the sandbox service (docker-compose sets SANDBOX_URL=
# http://sandbox:9000). Locally the backend spawns packages/sandbox/server.py on
# port 9100 (kept off 9000 so it never collides with Shannon) when nothing is
# already answering /health there. Set SANDBOX_AUTOSTART=false to disable.
# SANDBOX_URL=http://localhost:9100
# SANDBOX_AUTOSTART=true
# SANDBOX_LOCAL_PORT=9100
# SANDBOX_WORKSPACE=~/.speda/sandbox_workspace

# ── The Forge (Optimus Mark II execution engine) ────────────────────────────────
# SPEDA owns the Forge's lifecycle: set FORGE_DIR to the absolute path of the
# forge-mk1 repo and the backend launches it as a peer on startup
# (`uv run --project <dir> python -m forge connect --agent optimus`). It connects
# back to WS /agents/ws/optimus; when offline the in-process OptimusProfile
# answers. Leave FORGE_DIR empty to disable autostart.
# FORGE_AUTOSTART=true
# FORGE_DIR=C:\Users\AREL TARIM\forge-mk1
# FORGE_AGENT=optimus
# FORGE_WS_URL=ws://127.0.0.1:8000/agents/ws/optimus
# FORGE_CELL_BACKEND=auto
# FORGE_PYTHON=
