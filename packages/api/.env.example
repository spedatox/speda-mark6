# SPEDA Mark VI — backend environment. Copy to .env and fill in.
# Only ANTHROPIC_API_KEY and SPEDA_API_KEY are strictly required to boot.

# ── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Service credential the desktop app / scripts send (X-API-Key). Use a long
# random value:  python -c "import secrets;print(secrets.token_urlsafe(48))"
SPEDA_API_KEY=change-me

# ── Owner login (username/password -> JWT) — REQUIRED for the login page ──────
# Generate OWNER_PASSWORD_HASH + JWT_SECRET on a trusted machine:
#   python scripts/hash_password.py
# Plaintext is never stored. Empty JWT_SECRET => login disabled (fails closed).
OWNER_USERNAME=
OWNER_PASSWORD_HASH=
JWT_SECRET=
# JWT_TTL_SECONDS=43200        # session lifetime, default 12h

# n8n webhook trigger shared secret (X-N8N-Secret). Pick something strong.
N8N_SECRET=change-me

# ── CORS (browser origins only; leave empty for the desktop app) ─────────────
# Never "*" on a public server.
# CORS_ALLOWED_ORIGINS=https://app.example.com

# ── Database ────────────────────────────────────────────────────────────────
# Local dev defaults to SQLite (~/.speda/speda.db) — leave unset.
# In Docker, compose builds DATABASE_URL from POSTGRES_* below. CHANGE THE
# PASSWORD for prod (applies only on a fresh DB volume).
POSTGRES_USER=speda
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=speda
# DATABASE_URL=postgresql+asyncpg://speda:speda@postgres:5432/speda

# ── Web search (default toolset) ────────────────────────────────────────────
TAVILY_API_KEY=tvly-...
EXA_API_KEY=

# ── Notion (optional) ───────────────────────────────────────────────────────
NOTION_API_KEY=

# ── Google Workspace (optional) ─────────────────────────────────────────────
# One-time OAuth client from Google Cloud Console (Desktop type). Then use the
# in-app "Sign in with Google" button — it saves the refresh token for you.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# On the server, set this to the server's callback URL:
# GOOGLE_OAUTH_REDIRECT=https://your-server:8000/oauth/google/callback

# ── Other optional MCP servers ──────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=
BRAVE_SEARCH_API_KEY=
GITHUB_TOKEN=

# ── Domain (optional) ───────────────────────────────────────────────────────
# Set to serve over HTTPS via Caddy (auto Let's Encrypt). DNS A record must
# point at the server and ports 80/443 open. Leave blank for plain :8000.
# DOMAIN=speda.yourdomain.com
# When using a domain, also set the Google OAuth redirect to match:
# GOOGLE_OAUTH_REDIRECT=https://speda.yourdomain.com/oauth/google/callback

# ── Behaviour (optional — sensible defaults in config.py) ───────────────────
# MCP_ENABLED=tavily,google_gmail,google_calendar,notion
# BUDGET_MODE=true
# PROMPT_CACHE_TTL=1h
