<?xml version="1.0" encoding="utf-8"?>
<!-- The uplink API key lives in Keystore-wrapped prefs; nothing in this app is
     safe to back up or transfer off-device. Exclude everything. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>
